{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @soyboy/frontend build",
    "watchPatterns": ["/apps/frontend/**"],
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 0,
    "startCommand": "node --max-old-space-size=512 apps/frontend/.output/server/index.mjs",
    "limitOverride": {
      "containers": {
        "cpu": 2,
        "memoryBytes": 2000000000
      }
    },
    "sleepApplication": true,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": false,
    "multiRegionConfig": {
      "europe-west4-drams3a": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
