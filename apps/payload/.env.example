DATABASE_URL=postgresql://postgres:payload@postgres:5432/payload-vanilla
PAYLOAD_SECRET=YOUR_SECRET_HERE

# URLS 
FRONTEND_URL=http://localhost:4000
PAYLOAD_URL=http://localhost:3000

# Object storage (S3-compatible). On Cloudflare this points at an R2 bucket;
# R2 is S3-compatible so the same adapter works — only these values change.
#   S3_REGION       -> "auto" for R2
#   S3_ENDPOINT_URL -> https://<account_id>.r2.cloudflarestorage.com
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY -> R2 API token (S3 credentials)
#   S3_BUCKET_NAME  -> your R2 bucket name
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_REGION=auto
S3_BUCKET_NAME=soyboy-media
S3_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# --- Cloudflare Workers (Neon + Hyperdrive) ---
# DATABASE_URL above is the fallback for local dev / build / Payload CLI.
# On Workers the connection string comes from the HYPERDRIVE binding in
# wrangler.jsonc, not an env var. Point Hyperdrive at Neon's DIRECT string:
#   npx wrangler hyperdrive create soyboy-payload \
#     --connection-string="postgresql://<user>:<pass>@<host>.neon.tech/<db>?sslmode=require"
# then set the returned id in wrangler.jsonc.
#
# Secrets on Workers are set via `wrangler secret put <NAME>` (NOT this file):
#   PAYLOAD_SECRET (reuse the exact Railway value), S3_* creds, FRONTEND_URL, PAYLOAD_URL
