DATABASE_URL=postgresql://postgres:payload@postgres:5432/payload-vanilla
PAYLOAD_SECRET=YOUR_SECRET_HERE

# URLS 
FRONTEND_URL=http://localhost:4000
PAYLOAD_URL=http://localhost:3000

# S3 Storage
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_REGION=your_s3_region
S3_BUCKET=your_s3_bucket_name
S3_ENDPOINT_URL=your_s3_endpoint_url

# --- Cloudflare Workers (Path B: OpenNext + Hyperdrive) ---
# DATABASE_URL above is the fallback used for local dev / build / Railway.
# On Workers the connection string comes from the HYPERDRIVE binding in
# wrangler.jsonc, not an env var. Create it with:
#   npx wrangler hyperdrive create soyboy-payload --connection-string="postgres://..."
# then set the returned id in wrangler.jsonc.
