{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @soyboy/payload payload generate:importmap && pnpm --filter @soyboy/payload build",
    "watchPatterns": ["/apps/payload/**"],
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "preDeployCommand": ["pnpm --filter @soyboy/payload payload migrate"],
    "startCommand": "pnpm --filter @soyboy/payload start",
    "limitOverride": {
      "containers": {
        "cpu": 2,
        "memoryBytes": 2000000000
      }
    },
    "sleepApplication": false,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": false,
    "multiRegionConfig": {
      "europe-west4-drams3a": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
