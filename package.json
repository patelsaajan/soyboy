{
  "name": "soyboy",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:up": "docker compose -f apps/payload/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f apps/payload/docker-compose.yml stop postgres",
    "db:logs": "docker compose -f apps/payload/docker-compose.yml logs -f postgres",
    "db:reset": "docker compose -f apps/payload/docker-compose.yml down -v",
    "db:migrate:fresh": "pnpm --filter @soyboy/payload payload migrate:fresh",
    "db:seed": "pnpm --filter @soyboy/payload seed",
    "start": "pnpm db:up && pnpm dev"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
      "node": ">=22.13.0"
  },
    "packageManager": "pnpm@11.1.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
